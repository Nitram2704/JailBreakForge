# JailbreakForge Configuration
# Copy to .env and fill in your API keys

# REQUIRED: At least one LLM provider key
# JAILBREAKFORGE_GROQ_API_KEY=your-groq-api-key
# JAILBREAKFORGE_OPENROUTER_API_KEY=your-openrouter-api-key

# OPTIONAL: Default provider (groq or openrouter)
# JAILBREAKFORGE_PROVIDER=groq
# JAILBREAKFORGE_ATTACKER_MODEL=llama-3.1-8b-instant
# JAILBREAKFORGE_JUDGE_MODEL=llama-3.1-8b-instant
